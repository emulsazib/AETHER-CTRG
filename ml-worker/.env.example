# =============================================================================
# AETHER AI/ML Worker — environment template
# Copy to `.env`. The pipeline ships REAL models (CodeBERT/ResNet/CLIP/FAISS/
# SHAP/LIME + HF classifier) plus external LLM and OSINT; each degrades to a
# deterministic mock/static fallback when its deps/keys are absent.
# =============================================================================

# Port the FastAPI service listens on.
ML_WORKER_PORT=8000

# CORS: comma-separated origins allowed to call the worker directly (dev only).
ML_CORS_ORIGINS=http://localhost:4000,http://localhost:5173

# --- Real-model runtime ---
# Build the worker with the ML extras to enable the real models:
#   docker compose build --build-arg INSTALL_ML=true ml-worker   (default true)
ML_DEVICE=auto                     # auto|cpu|cuda|mps (auto => CUDA when present)
HF_HOME=/root/.cache/huggingface   # weight cache (mount a volume to persist)
TEXT_EMBED_MODEL_ID=microsoft/codebert-base
TEXT_EMBED_MAX_CHARS=4000
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k
STEGO_MIN_PRINTABLE=12             # min printable LSB run to flag a hidden payload
STEGO_MAX_BYTES=256
EMBEDDING_DIM=16                   # mock-fallback embedding size only

# --- Similarity clustering (FAISS/UMAP/KMeans) ---
CLUSTER_INDEX_DIR=/data/faiss      # persist the per-modality corpus embeddings
CLUSTER_KMEANS_K=5
CLUSTER_UMAP_NEIGHBORS=15

# --- Explainability (real SHAP + LIME over the classifier) ---
# Gated to ML-on + Deep sandbox mode because SHAP on transformers is slow.
XAI_REALSHAP=true
XAI_MAX_CHARS=1200
XAI_SHAP_MAX_EVALS=240
XAI_SHAP_TOPK=12
XAI_LIME_TOPK=5
XAI_LIME_SAMPLES=200

# --- External AI provider (IoC/TTP extraction, stego decode, summaries) ---
# ANY OpenAI-compatible gateway (OpenAI, vLLM, LiteLLM, Anthropic OpenAI-compat,
# self-hosted). Leave AI_API_KEY blank to use the deterministic mock extractor.
AI_API_KEY=
AI_BASE_URL=                       # e.g. https://api.openai.com/v1 (blank => OpenAI default)
AI_MODEL=gpt-4o-mini

# --- Trained ML classifier engine ---
# CLASSIFIER_PATH may be a local dir OR a HuggingFace hub id (auto-downloads on
# first use). Defaults to a real binary malicious/benign text classifier.
ML_CLASSIFIER_ENABLED=true         # default on/off; also toggleable live in the UI
CLASSIFIER_PATH=ealvaradob/bert-finetuned-phishing
CLASSIFIER_NAME=bert-finetuned-phishing
CLASSIFIER_BACKEND=hf              # hf (transformers) | onnx (local only)
CLASSIFIER_MALICIOUS_INDEX=1       # output index meaning "malicious" (phishing=1)
CLASSIFIER_THRESHOLD=0.5           # score >= threshold => malicious
CLASSIFIER_MAX_LEN=512
CLASSIFIER_PREFIX_TYPE=false       # keep false for general text classifiers

# --- External OSINT threat-intel (best-effort, key-gated) ---
# Any subset works; the engine is "available" when at least one key is set.
ABUSEIPDB_API_KEY=
OTX_API_KEY=
VT_API_KEY=
OSINT_MAX_IPS=6                    # per-sample lookup caps (protect free tiers)
OSINT_MAX_DOMAINS=4
OSINT_MAX_HASHES=4
OSINT_MAX_URLS=2
OSINT_CACHE_TTL=3600              # seconds to cache provider responses
ABUSEIPDB_MAX_AGE=90

# --- OpenCTI push (pycti) ---
# Turn on only once an OpenCTI platform is reachable (docker compose --profile opencti).
OPENCTI_ENABLED=false
OPENCTI_URL=http://opencti:8080
OPENCTI_TOKEN=                      # = OpenCTI admin token
