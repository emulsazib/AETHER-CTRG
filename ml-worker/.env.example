# =============================================================================
# AETHER AI/ML Worker — environment template
# Copy to `.env`. All external integration points are env-driven so mocks can
# be swapped for real services without code changes.
# =============================================================================

# Port the FastAPI service listens on.
ML_WORKER_PORT=8000

# CORS: comma-separated origins allowed to call the worker directly (dev only).
ML_CORS_ORIGINS=http://localhost:4000,http://localhost:5173

# --- External AI provider (IoC/TTP extraction) ---
# Routes LLM processing through ANY OpenAI-compatible gateway (OpenAI, vLLM,
# LiteLLM, Anthropic OpenAI-compat, self-hosted). Leave AI_API_KEY blank to use
# the deterministic mock extractor instead — no code change required.
AI_API_KEY=
AI_BASE_URL=                       # e.g. https://api.openai.com/v1 (blank => OpenAI default)
AI_MODEL=gpt-4o-mini

# --- OpenCTI push (pycti) ---
# Turn on only once an OpenCTI platform is reachable (docker compose --profile opencti).
OPENCTI_ENABLED=false
OPENCTI_URL=http://opencti:8080
OPENCTI_TOKEN=                      # = OpenCTI admin token

# --- Trained ML classifier engine (your own model) ---
# Enable build deps:  docker compose build --build-arg INSTALL_ML=true ml-worker
# Mount weights under ml-worker/models/ (see ml-worker/models/README.md).
ML_CLASSIFIER_ENABLED=false        # default on/off; also toggleable live in the UI
CLASSIFIER_PATH=                   # e.g. /models/malware-clf (empty => engine unavailable)
CLASSIFIER_NAME=Trained ML Classifier
CLASSIFIER_BACKEND=hf              # hf (transformers) | onnx
CLASSIFIER_MALICIOUS_INDEX=1       # output index meaning "malicious"
CLASSIFIER_THRESHOLD=0.5           # score >= threshold => malicious
CLASSIFIER_MAX_LEN=512

# Dimensionality of behavioral/image embedding vectors the mocks emit.
EMBEDDING_DIM=16
