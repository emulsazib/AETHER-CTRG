# =============================================================================
# AETHER API Gateway — environment template
# Copy to `.env`. If MongoDB/Neo4j are unreachable the gateway automatically
# falls back to in-memory stores (see src/config/*.js), so you can demo without
# Docker. All connection details live here — never hardcode them.
# =============================================================================

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

# MongoDB (matches docker-compose defaults)
MONGO_URI=mongodb://aether:aether_dev_pw@localhost:27017/aether?authSource=admin

# Neo4j (matches docker-compose defaults)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=aether_dev_pw

# AI/ML worker (FastAPI) base URL
ML_WORKER_URL=http://localhost:8000
ML_WORKER_TIMEOUT_MS=15000

# OSINT feed URLs — placeholders for real integrations (mocked from data/*.json)
ALIENVAULT_OTX_URL=https://otx.alienvault.com/api/v1
ABUSEIPDB_URL=https://api.abuseipdb.com/api/v2
