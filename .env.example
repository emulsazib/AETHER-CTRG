# =============================================================================
# AETHER Framework — ROOT environment template (shared / docker-compose)
# Copy to `.env` and adjust. Never commit the real `.env`.
# =============================================================================

# --- MongoDB (consumed by docker-compose and backend) ---
MONGO_USER=aether
MONGO_PASSWORD=aether_dev_pw
MONGO_DB=aether

# --- Neo4j (consumed by docker-compose and backend) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=aether_dev_pw

# =============================================================================
# External AI provider (ml-worker) — ANY OpenAI-compatible gateway.
# Replaces the blueprint's local Ollama. Leave AI_API_KEY blank to run the
# deterministic mock extractor (the stack still works end-to-end).
# =============================================================================
AI_API_KEY=
AI_BASE_URL=                       # e.g. https://api.openai.com/v1 (blank => OpenAI default)
AI_MODEL=gpt-4o-mini

# =============================================================================
# Real-model stack (ml-worker) — CodeBERT/ResNet/CLIP/FAISS/SHAP/LIME + classifier.
# INSTALL_ML bakes the heavy deps (torch/transformers/open_clip/faiss/...) into the
# image. ML_DEVICE=auto uses the GPU when the host exposes one (nvidia-container-toolkit).
# =============================================================================
INSTALL_ML=true                    # build-time: bake the real-model deps into the image
ML_DEVICE=auto                     # auto|cpu|cuda|mps
ML_WORKER_TIMEOUT_MS=30000         # gateway timeout (absorbs OSINT + first-call model load)

# Trained ML classifier — local dir OR a HuggingFace hub id (auto-downloads).
ML_CLASSIFIER_ENABLED=true         # default on/off (also toggleable live in the UI)
CLASSIFIER_PATH=ealvaradob/bert-finetuned-phishing
CLASSIFIER_NAME=bert-finetuned-phishing
CLASSIFIER_BACKEND=hf              # hf (transformers) | onnx (local only)
CLASSIFIER_MALICIOUS_INDEX=1       # output index that means "malicious"
CLASSIFIER_THRESHOLD=0.5           # score >= threshold => malicious
CLASSIFIER_PREFIX_TYPE=false       # keep false for general text classifiers

# =============================================================================
# External OSINT threat-intel (ml-worker) — IoC reputation + actor attribution.
# Best-effort and key-gated; the OSINT engine is "available" when >=1 key is set.
# =============================================================================
ABUSEIPDB_API_KEY=
OTX_API_KEY=
VT_API_KEY=

# =============================================================================
# OpenCTI attribution stack — ONLY used with `--profile opencti`.
# After the platform is healthy, set OPENCTI_ENABLED=true and copy
# OPENCTI_ADMIN_TOKEN into OPENCTI_TOKEN so ml-worker pushes STIX2 via pycti.
# =============================================================================
OPENCTI_ENABLED=false
OPENCTI_URL=http://opencti:8080
OPENCTI_TOKEN=                      # paste OPENCTI_ADMIN_TOKEN here to activate the push

OPENCTI_VERSION=6.4.1
OPENCTI_BASE_URL=http://localhost:8080
OPENCTI_ADMIN_EMAIL=admin@aether.local
OPENCTI_ADMIN_PASSWORD=aether_admin_password123
OPENCTI_ADMIN_TOKEN=d434ce02-2911-4c1a-9c1a-1a1b9c0a1aether   # replace with a real UUID
CONNECTOR_MITRE_ID=a3e1c5f2-7b4d-4e8a-9c6b-2f1d0e9a8b7c       # replace with a real UUID

# --- MinIO / RabbitMQ (OpenCTI stack credentials) ---
MINIO_ROOT_USER=aether_admin
MINIO_ROOT_PASSWORD=aether_password123
RABBITMQ_USER=aether
RABBITMQ_PASSWORD=aether_password123
